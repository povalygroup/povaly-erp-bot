# ============================================
# Telegram Operations Automation System
# Configuration Template
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# Bot Configuration
# ============================================
# Required: Your Telegram Bot API token from @BotFather
TELEGRAM_BOT_TOKEN=8419100961:AAGH5qc3Tr49vjZeCZNH_oYQUNRwY4T70eg

# Required: Telegram group ID where the bot operates (negative number for groups)
# To get group ID: Add bot to group, send a message, check https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_GROUP_ID=-1003901378950

# ============================================
# Database Configuration
# ============================================
# Database type: sqlite, mongodb, or json
# sqlite: Lightweight embedded database (recommended for single-server)
# mongodb: Distributed database (recommended for multi-server)
# json: File-based storage (recommended for development/testing only)
DATABASE_TYPE=sqlite

# Path to SQLite database file (used when DATABASE_TYPE=sqlite)
DATABASE_PATH=./data/povaly_bot.db

# Daily backup time in HH:MM format (GMT+6 timezone)
DATABASE_BACKUP_TIME=23:00

# MongoDB Configuration (only used when DATABASE_TYPE=mongodb)
# MONGO_URI=mongodb://username:password@localhost:27017/
# MONGO_DATABASE=povaly_bot

# JSON Storage Path (only used when DATABASE_TYPE=json)
# JSON_STORAGE_PATH=./data/json_storage

# ============================================
# Timezone
# ============================================
# System timezone for all time-based operations
TIMEZONE=GMT+6

# ============================================
# Topic IDs (Telegram Thread IDs)
# ============================================
# Required: Get these IDs from your Telegram group topics
# To get topic IDs: Enable topics in group, create topics, send message to each topic,
# check message thread_id in getUpdates API response

# Official announcements and directives (read-only for regular users)
TOPIC_OFFICIAL_DIRECTIVES=2

# Brand assets and resources (read-only for regular users)
TOPIC_BRAND_REPOSITORY=4

# Task creation and assignment (read-write for all users)
TOPIC_TASK_ALLOCATION=7

# Work discussions and collaboration (read-write for all users)
TOPIC_CORE_OPERATIONS=9

# Quality assurance submissions and reviews (read-write-react for QA reviewers)
TOPIC_QA_REVIEW=11

# Approved task archive (read-only for regular users)
TOPIC_CENTRAL_ARCHIVE=13

# Automated daily and weekly reports (read-only for regular users)
TOPIC_DAILY_SYNC=15

# Attendance tracking and leave requests (read-write-approve for managers)
TOPIC_ATTENDANCE_LEAVE=88

# Management escalations and alerts (managers/admins only)
TOPIC_ADMIN_CONTROL_PANEL=91

# Boardroom for daily/weekly/monthly reports (managers/admins only)
TOPIC_BOARDROOM=19

# Strategic discussions and casual communication (read-write for all users)
TOPIC_STRATEGIC_LOUNGE=1

# Trash topic for deleted messages (audit trail)
TOPIC_TRASH=5

# ============================================
# User Roles (Comma-separated Telegram User IDs)
# ============================================
# To get user IDs: Users send message to bot, check from_user.id in getUpdates

# Administrators: Full system access including configuration and security
# Example: 123456789,987654321
ADMINISTRATORS=7061459077

# Managers: Elevated permissions including leave approval and performance review
# Example: 111222333,444555666
MANAGERS=

# QA Reviewers: Authorized to approve/reject QA submissions
# Example: 777888999,123123123
QA_REVIEWERS=

# Owners: Ownership-level privileges equivalent to Administrators
# Example: 123456789
OWNERS=

# Admin DM Recipients: Subset of admins/managers who receive daily summary DMs
# Leave empty to disable admin DMs, or specify user IDs who want daily summaries
# Example: 123456789,987654321
# Note: These users will receive:
#   - Daily attendance summary (5:00 PM)
#   - Critical escalation digest (9:00 AM if any escalations)
#   - Weekly performance summary (Monday 9:00 AM)
ADMIN_DM_RECIPIENTS=

# ============================================
# Inactivity Thresholds (Hours)
# ============================================
# Hours before sending inactivity warning to assignee
INACTIVITY_WARNING_HOURS=18

# Hours before marking task as INACTIVE in reports
INACTIVITY_MARK_HOURS=24

# Hours before escalating to Admin Control Panel (manager notification)
INACTIVITY_ESCALATE_HOURS=48

# Hours before critical escalation (flagged in weekly report)
INACTIVITY_CRITICAL_HOURS=72

# Hours before task escalation alert to Admin Control Panel (default: 72 hours = 3 days)
TASK_ESCALATION_HOURS=72

# ============================================
# Attendance Configuration (HH:MM format GMT+6)
# ============================================
# Time after which check-in is considered late
ATTENDANCE_LATE_CHECKIN_TIME=11:00

# Time for automatic check-out if user hasn't checked out manually
ATTENDANCE_AUTO_CHECKOUT_TIME=23:59

# Expected end of workday (for attendance reports)
ATTENDANCE_EXPECTED_CHECKOUT_TIME=17:00

# Maximum total break time per day in minutes (default: 90 minutes = 1.5 hours)
# Alert sent to Admin Control Panel if exceeded
ATTENDANCE_MAX_BREAK_TIME_MINUTES=90

# Maximum number of breaks per day (default: 5 breaks)
# Alert sent to Admin Control Panel if exceeded
ATTENDANCE_MAX_BREAK_COUNT=5

# Number of late check-ins in a week before alerting admins (default: 3)
ATTENDANCE_LATE_CHECKIN_ALERT_COUNT=3

# Time to check for missing check-ins and alert admins (HH:MM format, default: 12:15 PM)
ATTENDANCE_MISSING_CHECKIN_ALERT_TIME=12:15

# ============================================
# QA Escalation Configuration
# ============================================
# Hours before QA submission is escalated with fire reaction and admin alert (default: 24 hours)
QA_ESCALATION_HOURS=24

# Hours before sending reminder to reviewers who claimed QA (default: 12 hours)
QA_REMINDER_HOURS=12

# ============================================
# Format Violation Tracking
# ============================================
# Number of format violations in same day before alerting admins (default: 3)
# First 2 violations send DM help to user, 3rd violation alerts admins
VIOLATION_ALERT_THRESHOLD=3

# ============================================
# Report Scheduling (GMT+6 timezone)
# ============================================
# Time for daily sync report generation (HH:MM format)
DAILY_REPORT_TIME=22:30

# Day of week for weekly report (Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Sunday)
WEEKLY_REPORT_DAY=Sunday

# Time for weekly report generation (HH:MM format)
WEEKLY_REPORT_TIME=22:30

# Time for daily summary messages in Task Allocation and QA Review topics (HH:MM format)
DAILY_SUMMARY_TIME=00:00

# ============================================
# Violation Handling
# ============================================
# Auto-delete malformed messages (true/false)
VIOLATION_AUTO_DELETE_MALFORMED=true

# Number of violations per week before escalation
VIOLATION_REPEATED_THRESHOLD=3

# Action for repeated violations: escalate_to_manager, log_only, or temporary_restriction
VIOLATION_REPEATED_ACTION=escalate_to_manager

# ============================================
# Brand Codes (Comma-separated)
# ============================================
# Valid brand codes for task tickets and QA submissions
# Example: PV,VB,XY,ZZ
BRAND_CODES=POV,VRB,GSM,BWN,BWS,

# ============================================
# Ticket Format Validation (Regex)
# ============================================
# Regular expression pattern for validating ticket format
# Default pattern: BRAND-DDMM-NUMBER (e.g., PV-2404-1)
TICKET_FORMAT_REGEX=^[A-Z]{2}-\d{4}-\d+$

# ============================================
# Notification Preferences
# ============================================
# Send direct messages to users for personal notifications (true/false)
NOTIFICATION_SEND_DM=true

# Send topic-based alerts to Admin Control Panel (true/false)
NOTIFICATION_SEND_TOPIC_ALERTS=true

# Include clickable message links in notifications (true/false)
NOTIFICATION_INCLUDE_MESSAGE_LINKS=true

# ============================================
# Performance Monitoring
# ============================================
# QA rejection rate threshold (0.0 to 1.0, e.g., 0.5 = 50%)
# Alert triggered when user's rejection rate exceeds this threshold
PERFORMANCE_QA_REJECTION_THRESHOLD=0.5

# Days without task completion before dormancy alert
PERFORMANCE_DORMANCY_DAYS=7

# Late check-ins per week before attendance alert
PERFORMANCE_LATE_CHECKIN_THRESHOLD=5

# ============================================
# Security
# ============================================
# Required: 32-character encryption key for sensitive data
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Keep this secret and never commit to version control
DATABASE_ENCRYPTION_KEY=CHANGE-THIS-TO-A-SECURE-32-CHAR-KEY

# Days to retain log files before deletion
LOG_RETENTION_DAYS=30

# Days to retain audit trail records before archival
AUDIT_TRAIL_RETENTION_DAYS=90

# ============================================
# Feature Flags
# ============================================
# Enable automatic check-out at ATTENDANCE_AUTO_CHECKOUT_TIME (true/false)
FEATURE_AUTO_CHECKOUT=true

# Enable automatic issue resolution (true/false)
FEATURE_AUTO_REMEDIATION=true

# Enable predictive performance alerts (true/false)
FEATURE_PREDICTIVE_ALERTS=true

# Enable analytics dashboard (true/false)
FEATURE_ANALYTICS_DASHBOARD=true

# Enable daily summary messages (true/false)
FEATURE_DAILY_SUMMARY=true
